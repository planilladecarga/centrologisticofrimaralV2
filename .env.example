# Copy this file to .env.local and replace placeholder values.
# You may commit this template (with placeholders only),
# but keep your real values in .env.local and out of git history).
NEXT_PUBLIC_FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="YOUR_PROJECT_ID.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="YOUR_PROJECT_ID"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="YOUR_PROJECT_ID.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="YOUR_MESSAGING_SENDER_ID"
NEXT_PUBLIC_FIREBASE_APP_ID="YOUR_FIREBASE_APP_ID"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="YOUR_FIREBASE_MEASUREMENT_ID"

# Optional: LAN endpoint for the temperature monitor in static deployments.
NEXT_PUBLIC_TEMPERATURE_ENDPOINT="http://192.168.150.31/TemperaturaWeb/temperatura.php"

# Server-side key used by API routes / server actions.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
